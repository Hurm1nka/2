<Window x:Class="SportProject.Views.AddEditOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SportProject.Views"
        mc:Ignorable="d"
        Title="Sport" Height="600" Width="1200">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>


        <Grid Grid.Row="0" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="3*"/>

            </Grid.ColumnDefinitions>
            <Image Source="/Resources/AppImages/Icon.png" Height="50"/>
            <Button Grid.Column="2" Content="Назад" Name="btnBack" Click="btnBack_Click"/>
            <TextBlock Name="tbTitle" Grid.Column="1" Text="???" Style="{StaticResource Title}"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <UniformGrid Rows="6" Columns="2">
                <TextBlock Text="Код заказа:"  Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxCode" IsReadOnly="True"/>
                <TextBlock Text="Статус заказа:" Style="{StaticResource TbEditForms}"/>
                <ComboBox Name="cbStatus" />
                <TextBlock Text="Адрес ПВЗ:" Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxPoint"/>
                <TextBlock Text="Дата заказа:" Style="{StaticResource TbEditForms}"/>
                <DatePicker Name="dpDateOrder"/>
                <TextBlock Text="Дата выдачи:" Style="{StaticResource TbEditForms}"/>
                <DatePicker Name="dpDateGet" />
                <TextBlock Text="ФИО авторизованного клиента:" Style="{StaticResource TbEditForms}"/>
                <ComboBox Name="cbClient"/>
            </UniformGrid>
        </Grid>
        <Grid Grid.Row="2" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="btnAddEdit" Content="???" Click="btnAddEdit_Click"/>
        </Grid>
    </Grid>
</Window>
