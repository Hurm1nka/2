<Window x:Class="SportProject.Views.AddEditProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SportProject.Views"
        mc:Ignorable="d"
        Title="Sport" Height="600" Width="1200">
    <Grid>
        
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            
           
            <Grid Grid.Row="0" Background="#7FFF00">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="3*"/>

                </Grid.ColumnDefinitions>
                <Image Source="/Resources/AppImages/Icon.png" Height="50"/>
                <Button Grid.Column="2" Content="Назад" Name="btnBack" Click="btnBack_Click"/>
                <TextBlock Name="tbTitle" Grid.Column="1" Text="???" Style="{StaticResource Title}"/>
            </Grid>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

            <UniformGrid Rows="11" Columns="2">
                <TextBlock Name="tbID" Text="ID:" Visibility="Collapsed"  Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxID" Visibility="Collapsed" IsReadOnly="True"/>
                <TextBlock Text="Артикул:"  Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxArticule" IsReadOnly="True"/>
                <TextBlock Text="Наименование товара:" Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxName" />
                <TextBlock Text="Категория:" Style="{StaticResource TbEditForms}"/>
                <ComboBox Name="cbCategory"/>
                <TextBlock Text="Описание товара:" Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxDescription"/>
                <TextBlock Text="Производитель:" Style="{StaticResource TbEditForms}"/>
                <ComboBox Name="cbManufacturer" />
                <TextBlock Text="Поставщик:" Style="{StaticResource TbEditForms}"/>
                <ComboBox Name="cbProvider"/>
                <TextBlock Text="Цена:" Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxCost" />
                <TextBlock Text="Единица измерения:" Style="{StaticResource TbEditForms}"/>
                <ComboBox Name="cbUnit"/>
                <TextBlock Text="Количество на складе:" Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxCount"/>
                <TextBlock Text="Действующая скидка:" Style="{StaticResource TbEditForms}"/>
                <TextBox Name="tbxDiscount"/>
            </UniformGrid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" >
                <Image Name="ImgPreview" Source="/Resources/Images/picture.png" MaxHeight="150"/>
                <TextBlock Name="tbImgPreview" Text="" TextAlignment="Center"/>
                <Button Content="???" Name="btnAddPhoto" Click="btnAddPhoto_Click"/>
            </StackPanel>

        </Grid>
        <Grid Grid.Row="2" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="btnAddEdit" Content="???" Click="btnAddEdit_Click"/>
        </Grid>
    </Grid>
  </Window>
