<Window x:Class="SportProject.Views.ProductCatalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SportProject.Views"
        mc:Ignorable="d"
        Title="Sport" Height="600" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Name="rowFooter" Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="3*"/>

            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Назад" Name="btnBack" Click="btnBack_Click"/> 
            <TextBlock Grid.Column="1" Text="Каталог" Style="{StaticResource Title}"/>
            <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"  Name="tbUsername"  Text="Гость"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox Name="lbProducts" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" MouseDoubleClick="lbProducts_MouseDoubleClick" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" BorderBrush="Black" BorderThickness="2"  Background="{Binding Path=StringColor}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <Border BorderBrush="Black" BorderThickness="1">
                                    <Image Source="{Binding Path=Photo}" MaxWidth="100px"/>
                                </Border>

                                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Margin="5,0,0,0" >
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold">
                                         <Run Text="{Binding Path=Categories.Name}"/>
                                         <Run Text="|"/>
                                         <Run Text="{Binding Path=ProductsNames.Name}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Path=Description, StringFormat=Описание товара: {0}}"/>
                                        <TextBlock Text="{Binding Path=Manufacturers.Name, StringFormat=Производитель: {0}}"/>
                                        <TextBlock Text="{Binding Path=Providers.Name, StringFormat=Поставщик: {0}}"/>
                                        <TextBlock>
                                         <Run Text="Цена:"/>         
                                         <Run Text="{Binding Path=Cost, StringFormat={}{0} руб.}" TextDecorations="{Binding Path=TextDecoration}" Foreground="{Binding Path=ActualCostColor}"/>
                                         <Run Text="{Binding Path=CostDiscount, Mode=OneWay,StringFormat={}{0}}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Path=Units.Name, StringFormat=Единица измерения: {0}}"/>
                                        <TextBlock Text="{Binding Path=Count, StringFormat=Количество на складе: {0}}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" BorderThickness="1" BorderBrush="Black" Margin="5,0,0,0">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=Discount, StringFormat={}{0}%}"/>
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>


            <Grid Name="gridFilters" Visibility="Collapsed" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Фильтры" Style="{StaticResource Title}"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Поиск"/>
                    <TextBox Name="tbxSearch" TextChanged="tbxSearch_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Сортировка по кол-ву"/>
                    <RadioButton Name="rbUp" Content="По возрастанию" Checked="rbUp_Checked"/>
                    <RadioButton Name="rbDown" Content="По убыванию" Checked="rbDown_Checked"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Фильтр по поставщику"/>
                    <ComboBox Name="cbProviders" SelectionChanged="cbProviders_SelectionChanged"/>
                </StackPanel>

            </Grid>

        </Grid>


        <UniformGrid Name="gridFooter" Grid.Row="2" Visibility="Visible" Rows="1" Background="#7FFF00" >
            <Button  Name="btnAdd" Visibility="Collapsed" Content="Добавить товар" Click="btnAdd_Click"/>
            <Button  Name="btnDelete" Visibility="Collapsed" Content="Удалить" Click="btnDelete_Click"/>
            <Button  Name="btnOrders" Content="Заказы" Click="btnOrders_Click"/>
        </UniformGrid>
        
       </Grid>
</Window>
